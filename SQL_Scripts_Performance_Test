CREATE DATABASE bd_jorge_carmona_mulata;

/*
	Table Creation
*/

-- Dim_Cities
CREATE TABLE cities (
	id SERIAL PRIMARY KEY,
	city_name VARCHAR(100) NOT NULL UNIQUE
);

-- Dim_Categories
CREATE TABLE categories (
	id SERIAL PRIMARY KEY,
	category_name VARCHAR(100) NOT NULL UNIQUE
);

-- Dim_Suppliers
CREATE TABLE suppliers(
	id SERIAL PRIMARY KEY,
	supplier_name VARCHAR(100) NOT NULL UNIQUE,
	id_city INT NOT NULL,
	FOREIGN KEY (id_city) REFERENCES cities(id)
);

-- Dim_Warehouses
CREATE TABLE warehouses(
	id SERIAL PRIMARY KEY,
	warehouse_name VARCHAR(100) NOT NULL,
	id_city INT NOT NULL,
	FOREIGN KEY (id_city) REFERENCES cities(id)
);

-- Dim_Products
CREATE TABLE products(
	id SERIAL PRIMARY KEY,
	product_name VARCHAR(150) NOT NULL UNIQUE,
	id_category INT NOT NULL,
	FOREIGN KEY (id_category) REFERENCES categories(id)
);

-- FT_Inventory_Movements
CREATE TABLE inventory_movements(
	id SERIAL PRIMARY KEY,
	movement_type VARCHAR(20) NOT NULL,
	quantity INT NOT NULL CHECK (quantity > 0),
	unit_price numeric NOT NULL CHECK (unit_price >= 0)
);

-- FT_Purcharses
CREATE TABLE purcharses(
	id SERIAL PRIMARY KEY,
	purcharse_order VARCHAR(50) NOT NULL, -- Tal vez colocar este así o como id?
	movement_date DATE NOT NULL,
	id_supplier INT NOT NULL,
	id_warehouse INT NOT NULL,
	id_product INT NOT NULL,
	id_movement INT NOT NULL,
	FOREIGN KEY (id_supplier) REFERENCES suppliers(id),
	FOREIGN KEY (id_warehouse) REFERENCES warehouses(id),
	FOREIGN KEY (id_product) REFERENCES products(id),
	FOREIGN KEY (id_movement) REFERENCES inventory_movements(id)	
);
